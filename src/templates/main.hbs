<body style="margin:0; padding:0; background-color:#ffffff; -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%;">
    <table width="100%" border="0" cellpadding="0" cellspacing="0" bgcolor="#ffffff" style="table-layout:fixed;">
        <tr>
            <td align="center">
                <table width="640" border="0" cellpadding="0" cellspacing="0" style="width:640px; margin:0 auto; border-collapse:collapse; background-color:#ffffff;">
                    {{> header}}
                    {{{content}}}
                    {{> footer}}
                </table>
            </td>
        </tr>
    </table>
</body>