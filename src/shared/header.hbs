<tr>
  <td align="center" bgcolor="#ffffff">
    <div style="display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
      {{meta.preheader}}
    </div>
    <table width="640" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding:10px;font-size:12px;">
          <a href="{{meta.browser_url}}" style="color:#888;text-decoration:underline;">
            View in browser
          </a>
        </td>
      </tr>
    </table>

    <table width="640" cellpadding="0" cellspacing="0" bgcolor="#ffffff">
      <tr>
        <td align="center" style="padding:25px;">
          <a href="{{brand.url}}">
            <img src="{{brand.logo}}" width="180" alt="{{brand.name}}" style="display:block;border:0;">
          </a>
        </td>
      </tr>
    </table>
  </td>
</tr>